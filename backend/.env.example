# =====================================================================
# Backend environment variables — copy to `.env` and fill in real values
#   cp .env.example .env
# docker-compose reads this file automatically. Do NOT commit `.env`.
# =====================================================================

# ----- Database (Postgres) -----
# Consumed by docker-compose for both the `db` and `app` services.
DB_USERNAME=crm_user
DB_PASSWORD=change_me_strong_password

# ----- JWT -----
# MUST be a Base64 string that decodes to at least 32 bytes (256 bits) for HS256.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=replace_with_base64_secret_at_least_32_bytes

# ----- Firebase (push notifications) -----
# Optional. If left blank / credentials file is absent, push notifications
# are disabled and the app still boots normally.
FIREBASE_PROJECT_ID=

# ----- pgAdmin (only used by the `dev` compose profile) -----
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me
